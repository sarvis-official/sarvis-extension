{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "moduleResolution": "Node16",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "sourceMap": true,
        "esModuleInterop": true,
        "jsx": "react-jsx",
        "skipLibCheck": true,
        "types": [
            "node",
            "vscode"
        ]
    },
    "exclude": [
        "node_modules",
        ".vscode-test"
    ]
}