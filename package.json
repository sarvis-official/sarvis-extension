{
  "name": "sarvis-extension",
  "displayName": "Sarvis",
  "description": "Sarvis AI-powered developer assistant for VS Code.",
  "version": "0.1.0",
  "publisher": "sarvis-official",
  "license": "MIT",
  "private": false,
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Other"
  ],
  "keywords": [
    "sarvam",
    "sarvam-ai",
    "ai",
    "assistant",
    "chatbot",
    "developer-tools",
    "productivity",
    "typescript",
    "vscode-extension",
    "llm",
    "sarvis"
  ],
  "icon": "assets/icons/sarvis.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarvis-official/sarvis-extension.git"
  },
  "homepage": "https://github.com/sarvis-official/sarvis-extension",
  "bugs": {
    "url": "https://github.com/sarvis-official/sarvis-extension/issues"
  },
  "activationEvents": [
    "onStartupFinished",
    "onCommand:sarvis.openChat",
    "onCommand:sarvis.clearChat",
    "onView:sarvis.sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "sarvis.openChat",
        "title": "Sarvis: Open Chat"
      },
      {
        "command": "sarvis.clearChat",
        "title": "Sarvis: Clear Chat"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "sarvis",
          "title": "Sarvis",
          "icon": "assets/icons/sarvis.png"
        }
      ]
    },
    "views": {
      "sarvis": [
        {
          "type": "webview",
          "id": "sarvis.sidebar",
          "name": "Sarvis Chat"
        }
      ]
    },
    "configuration": {
      "title": "Sarvis",
      "properties": {
        "sarvis.apiKey": {
          "type": "string",
          "default": "",
          "markdownDescription": "Sarvam AI API Key"
        },
        "sarvis.model": {
          "type": "string",
          "default": "sarvam-m",
          "markdownDescription": "Default Sarvam AI model"
        }
      }
    }
  },
  "scripts": {
    "clean": "node scripts/clean.js",
    "build": "webpack --mode production",
    "dev": "webpack --mode development --watch",
    "compile": "tsc -p ./",
    "lint": "eslint src --ext .ts,.tsx",
    "prettier": "prettier --write .",
    "prettier:check": "prettier --check .",
    "test": "echo \"No tests yet\"",
    "package": "vsce package"
  },
  "dependencies": {
    "dotenv": "^16.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sarvamai": "^1.1.7"
  },
  "devDependencies": {
    "@types/node": "^22.15.18",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@types/vscode": "^1.120.0",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^2.5.2",
    "css-loader": "^7.1.2",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-react": "^7.37.5",
    "html-webpack-plugin": "^5.6.3",
    "prettier": "^3.5.3",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.2",
    "typescript": "^5.8.3",
    "vsce": "^2.15.0",
    "webpack": "^5.99.9",
    "webpack-cli": "^6.0.1"
  }
}
