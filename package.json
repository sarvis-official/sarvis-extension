    "configuration": {
      "title": "Sarvis",
      "properties": {
        "sarvis.reviewOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Automatically review code when saving a file"
        },
        "sarvis.errorExplainer": {
          "type": "boolean",
          "default": true,
          "description": "Show AI-powered error explanations on hover"
        },
        "sarvis.errorExplainerDelay": {
          "type": "number",
          "default": 500,
          "description": "Delay in ms before fetching error explanation on hover"
        },
        "sarvis.customSnippetTriggers": {
          "type": "object",
          "default": {},
          "description": "Custom snippet triggers. Key = trigger word, Value = description of what to generate."
        },
        "sarvis.completionMode": {
          "type": "string",
          "enum": [
            "conservative",
            "balanced",
            "creative"
          ],
          "default": "balanced",
          "description": "Controls how aggressively Sarvis suggests inline completions."
        },
        "sarvis.showBranding": {
          "type": "boolean",
          "default": true,
          "description": "Show Sarvis branding when suggestion is accepted."
        }
      }
